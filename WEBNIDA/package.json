{
  "name": "webnida-bakery",
  "version": "1.0.0",
  "private": true,
  "description": "Página web profesional para venta de panes, pasteles y productos de repostería",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "powershell -NoProfile -Command \"$ca=(Resolve-Path '.\\\\tools\\\\cacert.pem').Path; & .\\\\tools\\\\php\\\\php.exe -d curl.cainfo=\\\"$ca\\\" -d openssl.cafile=\\\"$ca\\\" -S 0.0.0.0:5001 -t backend\\\\public backend\\\\server.php\"",
    "frontend": "cd frontend && npx next dev --port 3000",
    "frontend:build": "cd frontend && npm run build",
    "frontend:start": "cd frontend && npm run start -- -p 3000",
    "build": "cd frontend && npm run build",
    "install-all": "npm install && cd frontend && npm install"
  },
  "keywords": ["bakery", "pasteles", "panes", "repostería", "ecommerce"],
  "author": "Delicias Bakery",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}
